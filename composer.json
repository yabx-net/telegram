{
  "name": "yabx/telegram",
  "description": "Telegram Bot API SDK for PHP 8.1+",
  "keywords": ["telegram", "bot", "api", "sdk", "telegram bot", "telegram bot api", "telegram sdk", "telegram php"],
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Yabx\\Telegram\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Yabx\\Telegram\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Yauheni Kiryienkau",
      "email": "ya@yabx.net"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-curl": "*",
    "guzzlehttp/guzzle": "^7.9",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "ext-mbstring": "*",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "php scripts/coverage.php",
    "test:coverage-html": "php scripts/coverage.php --coverage-html build/coverage",
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist"
  },
  "suggest": {
    "ext-pcov": "Required for local code coverage (composer test:coverage)"
  }
}
